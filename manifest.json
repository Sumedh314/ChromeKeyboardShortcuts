{
    "manifest_version": 3,
    "name": "Chrome Keyboard Shortcuts",
    "version": 1.0,
    
    "background": {
        "service_worker": "background.js"
    },

    "commands": {
        "new_tab_in_group": {
            "suggested_key": {
                "default": "Ctrl+I",
                "mac": "Command+I"
            },
            "description": "Add a new tab in the current group"
        }
    }
}